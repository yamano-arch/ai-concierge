# Anthropic API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# TalkLabel設定 (talklabel/)
# ─────────────────────────────────────────────────────────────
TALKLABEL_EMAIL=your_talklabel_email@example.com
TALKLABEL_PASSWORD=your_talklabel_password
GOOGLE_SHARE_EMAIL=your_email@example.com

# ─────────────────────────────────────────────────────────────
# LINE Bot設定 (line_bot/)
# ─────────────────────────────────────────────────────────────
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheets設定
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/service_account.json
GOOGLE_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SHEET_NAME=名刺データ

# アプリ設定
APP_HOST=0.0.0.0
APP_PORT=8000

# ─────────────────────────────────────────────────────────────
# こどもAIコンシェルジュ (concierge/)
# ─────────────────────────────────────────────────────────────

# Google Places API（施設データ収集）
CONCIERGE_PLACES_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ※ イベント収集（fetch_events_from_search.py）は
#   Jina Search + Jina Reader を使用するため追加キー不要（無料）

# ─────────────────────────────────────────────────────────────
# MEO営業ツール設定 (meo_sales/)
# ─────────────────────────────────────────────────────────────

# Google Places API キー（飲食店リスト収集に使用）
# 取得: https://console.cloud.google.com/ → Places API を有効化
# ※ 月200ドル分の無料クレジットあり（約6,000件の Nearby Search に相当）
GOOGLE_PLACES_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram アカウント（DM送信用 ※営業専用サブアカウント推奨）
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# DM送信者として表示されるアカウント名（省略時: 山田（ATARAYO））
INSTAGRAM_SENDER_NAME=山田（ATARAYO）

# MEO営業用スプレッドシートID（省略時は GOOGLE_SPREADSHEET_ID を使用）
# 別スプレッドシートを使う場合は新規作成して ID を設定
# MEO_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Meta Ad Library API設定 (meta_ad_library/)
# ─────────────────────────────────────────────────────────────

# Metaアクセストークン（ads_read パーミッション必要）
# 取得: https://developers.facebook.com/tools/explorer/
META_AD_LIBRARY_TOKEN=your_meta_access_token_here
